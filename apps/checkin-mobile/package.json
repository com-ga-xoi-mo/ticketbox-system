{
  "name": "@ticketbox/checkin-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "TicketBox React Native check-in staff mobile app.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --config vitest.config.mts",
    "verify": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@expo/env": "^2.0.11",
    "@expo/image-utils": "^0.10.1",
    "@react-native-community/netinfo": "11.4.1",
    "@ticketbox/api-types": "0.1.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-camera": "~17.0.10",
    "expo-crypto": "~15.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.10"
  }
}
