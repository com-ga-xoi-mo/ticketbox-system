NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://ticketbox:ticketbox@localhost:5432/ticketbox?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
QUEUE_PREFIX=ticketbox
INTERNAL_API_KEY=ticketbox-internal-dev-key
JWT_SECRET=changeme
JWT_EXPIRY=1h
BCRYPT_ROUNDS=12
QR_TOKEN_SECRET=ticketbox-qr-token-dev-secret
ORDER_RESERVATION_TTL_MINUTES=15
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REQUEST_TYPE=captureWallet
MOMO_RETURN_URL=http://localhost:3000/payment-return
MOMO_IPN_URL=http://localhost:3000/payments/momo/ipn
VNPAY_TMN_CODE=your_vnpay_terminal_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payments/vnpay/return
VNPAY_IPN_URL=https://your-public-tunnel.example/payments/vnpay/ipn
VNPAY_VERSION=2.1.0
VNPAY_COMMAND=pay
VNPAY_LOCALE=vn
VNPAY_ORDER_TYPE=other
VNPAY_EXPIRE_MINUTES=15
EMAIL_PROVIDER=local
EMAIL_FROM=no-reply@ticketbox.test
EMAIL_MAX_ATTEMPTS=3
EMAIL_RETRY_BACKOFF_MS=5000
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
# Authenticated SMTP (e.g. Gmail). Leave USER/PASS empty for the local Maildev demo.
# Gmail: EMAIL_PROVIDER=smtp, EMAIL_SMTP_HOST=smtp.gmail.com, EMAIL_SMTP_PORT=587,
#        EMAIL_SMTP_SECURE=false, EMAIL_SMTP_USER=<you>@gmail.com,
#        EMAIL_SMTP_PASS=<16-char App Password> (requires 2FA; not your normal password).
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_SECURE=false
MAILDEV_WEB_URL=http://localhost:1080
ARTIST_BIO_PDF_MAX_BYTES=5242880
ARTIST_BIO_INPUT_MAX_CHARS=12000
ARTIST_BIO_MAX_ATTEMPTS=3
# Maximum SVG upload size for concert seating maps, in bytes.
SEATING_MAP_SVG_MAX_BYTES=5242880
# Maximum raster image upload size for concert posters, in bytes.
POSTER_IMAGE_MAX_BYTES=5242880
AI_ARTIST_BIO_PROVIDER=local
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_MS=10000
GUEST_LIST_DISCOVERY_CRON=*/5 * * * *
GUEST_LIST_INBOX_PATH=data/guest-list-inbox
GUEST_LIST_ARCHIVE_PATH=data/guest-list-archive
GUEST_LIST_STORAGE_PATH=data/guest-list-storage
GUEST_LIST_MAX_BYTES=5242880
GUEST_LIST_MAX_ROWS=10000
GUEST_LIST_MAX_ATTEMPTS=5
GUEST_LIST_RETRY_BACKOFF_MS=5000
GUEST_LIST_PROCESSING_LEASE_MS=120000

# Object storage
# Use local for development/test fallback. Use s3 for Cloudflare R2 or another S3-compatible provider.
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT_DIR=data/uploads
LOCAL_STORAGE_PUBLIC_BASE_URL=http://localhost:3000/storage

# Required only when STORAGE_DRIVER=s3.
S3_ENDPOINT=https://example-account.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=ticketbox-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://assets.example.com
