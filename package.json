{
  "name": "ticketbox-system",
  "version": "0.1.0",
  "private": true,
  "description": "TicketBox platform foundation workspace.",
  "license": "UNLICENSED",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:deps": "docker compose up -d postgres redis maildev",
    "stop:deps": "docker compose down",
    "build:api-types": "npm --workspace @ticketbox/api-types run build",
    "dev:api": "npm run build:api-types && nest start api --watch",
    "dev:worker": "nest start worker --watch",
    "dev:checkin-mobile": "npm run build:api-types && npm --workspace @ticketbox/checkin-mobile run start",
    "build": "npm run build:api-types && nest build api && nest build worker",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build:api-types && vitest run --passWithNoTests",
    "test:api-types": "npm --workspace @ticketbox/api-types run test",
    "test:checkin-mobile": "npm --workspace @ticketbox/checkin-mobile run test",
    "test:e2e": "vitest run test/**/*.e2e-spec.ts",
    "health": "node tools/check-health.mjs",
    "verify:workspace": "node tools/verify-workspace.mjs",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "verify:prisma": "prisma validate && prisma generate",
    "verify:database": "node tools/verify-database-seed.mjs",
    "verify:checkin-mobile": "npm run build:api-types && npm --workspace @ticketbox/checkin-mobile run verify",
    "verify:api-boundaries": "node tools/verify-api-types-boundaries.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cron-parser": "^4.9.0",
    "ioredis": "^5.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.15.41",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  }
}
