    {
      "name": "3. Check-in Staff Assignment Admin",
      "item": [
        {
          "name": "List Active Staff Assignments For Concert",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (Array.isArray(json) && json.length > 0) {",
                  "    pm.collectionVariables.set('assignmentId', json[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/concerts/{{concertId}}/staff",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "concerts", "{{concertId}}", "staff"]
            }
          }
        },
        {
          "name": "Assign Staff To Concert",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) pm.collectionVariables.set('assignmentId', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"staffUserId\": \"{{staffUserId}}\",\n  \"gateName\": \"Postman Gate\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/concerts/{{concertId}}/staff",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "concerts", "{{concertId}}", "staff"]
            }
          }
        },
        {
          "name": "Revoke Staff Assignment",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/concerts/{{concertId}}/staff/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "concerts", "{{concertId}}", "staff", "{{assignmentId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Check-in Mobile API Boundary - Future",
      "description": "These endpoints are expected by the mobile app boundary, but backend implementation belongs to implement-checkin-api and may return 404 now.",
      "item": [
        {
          "name": "Future - Load My Staff Assignments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{staffToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/checkin/assignments",
              "host": ["{{baseUrl}}"],
              "path": ["checkin", "assignments"]
            }
          }
        },
        {
          "name": "Future - Submit Online Scan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{staffToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignmentId\": \"{{assignmentId}}\",\n  \"concertId\": \"{{concertId}}\",\n  \"gate\": \"Main Gate\",\n  \"qrPayload\": \"ticketbox-demo-opaque-qr-payload\",\n  \"scannedAt\": \"2026-08-01T12:00:00.000Z\",\n  \"deviceId\": \"postman-device-1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/checkin/scan",
              "host": ["{{baseUrl}}"],
              "path": ["checkin", "scan"]
            }
          }
        }
      ]
    }
