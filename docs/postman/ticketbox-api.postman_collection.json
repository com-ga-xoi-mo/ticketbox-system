              "mode": "raw",
              "raw": "{\n  \"slug\": \"{{uniqueSlug}}\",\n  \"title\": \"Admin Postman Concert\",\n  \"artistName\": \"Admin Artist\",\n  \"venueName\": \"Admin Arena\",\n  \"venueAddress\": \"456 Demo Street\",\n  \"city\": \"Ho Chi Minh City\",\n  \"startsAt\": \"2026-09-01T13:00:00.000Z\",\n  \"endsAt\": \"2026-09-01T16:00:00.000Z\",\n  \"description\": \"Created by admin from Postman.\"\n}"
            },
            "url": {
