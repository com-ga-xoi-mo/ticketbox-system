    {
      "name": "2. Organizer and Admin Concert Management",
      "item": [
        {
          "name": "Organizer Create Concert",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('uniqueSlug', `postman-demo-${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('organizer can create concert', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 200]);",
                  "  pm.expect(pm.response.json()).to.have.property('id');",
                  "});",
                  "pm.collectionVariables.set('createdConcertId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{organizerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"{{uniqueSlug}}\",\n  \"title\": \"Postman Demo Concert\",\n  \"artistName\": \"Postman Artist\",\n  \"venueName\": \"Postman Arena\",\n  \"venueAddress\": \"123 Demo Street\",\n  \"city\": \"Ha Noi\",\n  \"startsAt\": \"2026-08-01T13:00:00.000Z\",\n  \"endsAt\": \"2026-08-01T16:00:00.000Z\",\n  \"description\": \"Created from Postman collection.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/organizer/concerts",
              "host": ["{{baseUrl}}"],
              "path": ["organizer", "concerts"]
            }
          }
        },
        {
          "name": "Organizer Create Ticket Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('organizer can create ticket type', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 200]);",
                  "  pm.expect(pm.response.json()).to.have.property('id');",
                  "});",
                  "pm.collectionVariables.set('ticketTypeId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{organizerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"POSTMAN\",\n  \"name\": \"Postman Ticket\",\n  \"description\": \"Ticket type created from Postman.\",\n  \"priceVnd\": 1000000,\n  \"totalQuantity\": 100,\n  \"saleStartsAt\": \"2026-07-01T00:00:00.000Z\",\n  \"saleEndsAt\": \"2026-07-31T23:59:59.000Z\",\n  \"maxPerUser\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/organizer/concerts/{{createdConcertId}}/ticket-types",
              "host": ["{{baseUrl}}"],
              "path": ["organizer", "concerts", "{{createdConcertId}}", "ticket-types"]
            }
          }
        },
        {
          "name": "Organizer Publish Concert",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{organizerToken}}"
