  "item": [
    {
      "name": "0. Health and Public Catalog",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "List Public Concerts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns concerts array', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "const concerts = pm.response.json();",
                  "if (concerts.length > 0) {",
                  "  pm.collectionVariables.set('concertId', concerts[0].id);",
                  "  pm.collectionVariables.set('concertSlug', concerts[0].slug);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/concerts",
              "host": ["{{baseUrl}}"],
              "path": ["concerts"]
            }
          }
        },
        {
          "name": "Get Concert Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns concert detail', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('ticketTypes');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/concerts/{{concertSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["concerts", "{{concertSlug}}"]
            }
          }
        },
        {
          "name": "Get Concert Availability",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/concerts/{{concertSlug}}/availability",
              "host": ["{{baseUrl}}"],
              "path": ["concerts", "{{concertSlug}}", "availability"]
            }
          }
        }
      ]
    },
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login Audience",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('audience login returns token', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  pm.expect(pm.response.json()).to.have.property('accessToken');",
                  "});",
                  "pm.collectionVariables.set('audienceToken', pm.response.json().accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
