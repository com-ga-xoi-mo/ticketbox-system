              "raw": "{\n  \"email\": \"new-audience-{{$timestamp}}@ticketbox.test\",\n  \"password\": \"demoPassword\",\n  \"displayName\": \"New Audience {{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
