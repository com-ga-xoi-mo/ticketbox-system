        {
          "name": "Organizer Upload Seating Map SVG",
          "description": "In Postman, set Body -> form-data -> key `file` to type `File` and choose a local `.svg` file. Use a safe SVG for success requests; use an SVG containing `<script>` for the unsafe negative test.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Organizer Upload Seating Map SVG returns 201', function () {",
                  "  pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.expect(body).to.have.property('asset');",
                  "pm.expect(body.asset).to.have.property('id');",
                  "pm.expect(body.asset.kind).to.equal('SEATING_MAP');",
                  "pm.expect(body.asset.storageKey).to.include('seating-maps/');",
                  "pm.expect(body.asset).to.have.property('publicUrl');",
                  "pm.expect(body.asset.checksum).to.match(/^sha256:/);",
                  "pm.expect(body.concert.seatingMapAssetId).to.equal(body.asset.id);",
                  "pm.collectionVariables.set('seatingMapAssetId', body.asset.id);",
                  "pm.collectionVariables.set('seatingMapStorageKey', body.asset.storageKey);",
                  "pm.collectionVariables.set('seatingMapPublicUrl', body.asset.publicUrl || '');"
                ]
              }
            }
          ],
