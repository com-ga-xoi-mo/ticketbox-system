        {
          "name": "Me Profile - Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('staff profile returns id and roles', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json.roles).to.include('CHECKIN_STAFF');",
                  "});",
                  "pm.collectionVariables.set('staffUserId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
