                  "  pm.expect(pm.response.json()).to.have.property('zones');",
                  "});",
                  "const zones = pm.response.json().zones || [];",
                  "const vip = zones.find((zone) => zone.svgElementId === 'zone-vip');",
                  "const ga = zones.find((zone) => zone.svgElementId === 'zone-ga');",
                  "pm.expect(vip).to.not.be.undefined;",
                  "pm.expect(ga).to.not.be.undefined;",
                  "pm.collectionVariables.set('zoneVipId', vip.id);",
                  "pm.collectionVariables.set('zoneGaId', ga.id);"
                ]
