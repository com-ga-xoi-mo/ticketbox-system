{
  "info": {
    "_postman_id": "54b61ff8-9b9b-477f-b122-60907e6cbcb7",
    "name": "TicketBox Order Lifecycle",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Manual test collection for the implemented order lifecycle flow on local TicketBox backend."
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1.1 Register Audience User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('email')) {",
                  "  pm.environment.set('email', `aud-${Date.now()}@example.com`);",
                  "}",
                  "if (!pm.environment.get('password')) {",
                  "  pm.environment.set('password', '12345678');",
                  "}",
                  "if (!pm.environment.get('displayName')) {",
                  "  pm.environment.set('displayName', 'Postman Audience');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or 409', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.accessToken) {",
                  "    pm.environment.set('accessToken', body.accessToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"displayName\": \"{{displayName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates an AUDIENCE user. If the email already exists, Postman should show 409 and you can move to Login."
          },
          "response": []
        },
        {
          "name": "1.2 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.environment.set('accessToken', body.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs in and stores the returned JWT in {{accessToken}}."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Orders",
      "item": [
        {
          "name": "2.1 Create Order",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('idempotencyKey')) {",
                  "  pm.environment.set('idempotencyKey', `idem-${Date.now()}`);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or 200', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.environment.set('orderId', body.id);",
                  "pm.test('order is pending payment', function () {",
                  "  pm.expect(body.status).to.eql('PENDING_PAYMENT');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"concertId\": \"{{concertId}}\",\n  \"idempotencyKey\": \"{{idempotencyKey}}\",\n  \"items\": [\n    {\n      \"ticketTypeId\": \"{{ticketTypeId}}\",\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/checkout/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "checkout",
                "orders"
              ]
            },
            "description": "Creates a new order and stores the response id in {{orderId}}. You must fill {{concertId}} and {{ticketTypeId}} first."
          },
          "response": []
        },
        {
          "name": "2.2 Create Order Again (Same Idempotency Key)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 or 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('duplicate request returns the same order id', function () {",
                  "  pm.expect(body.id).to.eql(pm.environment.get('orderId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"concertId\": \"{{concertId}}\",\n  \"idempotencyKey\": \"{{idempotencyKey}}\",\n  \"items\": [\n    {\n      \"ticketTypeId\": \"{{ticketTypeId}}\",\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/checkout/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "checkout",
                "orders"
              ]
            },
            "description": "Sends the same payload again to verify idempotency."
          },
          "response": []
        },
        {
          "name": "2.3 List My Orders",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/me/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "me",
                "orders"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2.4 Get My Order",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/me/orders/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "me",
                "orders",
                "{{orderId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Internal Order Status",
      "item": [
        {
          "name": "3.1 Mark Order As PAID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('order is marked paid', function () {",
                  "  pm.expect(body.status).to.eql('PAID');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-internal-api-key",
                "value": "{{internalApiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PAID\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}",
                "status"
              ]
            },
            "description": "Internal-only endpoint protected by x-internal-api-key."
          },
          "response": []
        },
        {
          "name": "3.2 Invalid Transition After PAID -> EXPIRED",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-internal-api-key",
                "value": "{{internalApiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EXPIRED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}",
                "status"
              ]
            },
            "description": "Negative test: once PAID, EXPIRED should be rejected."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ]
}
